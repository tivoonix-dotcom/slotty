VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# SLOTTY backend (Express). Пример: http://localhost:4000
VITE_API_URL=http://localhost:4000

# --- Ниже для npm run dev (подхватываются в server/.env автоматически) ---
# Supabase → Settings → Database → Connection string (Transaction pooler, URI)
#DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Supabase → Settings → API → service_role (не anon / publishable)
#SUPABASE_SERVICE_ROLE_KEY=eyJ...
#JWT_SECRET=any-random-string-at-least-16-chars
# true = не подставлять мок Telegram на localhost (см. src/shared/lib/devTelegramMock.ts).
# В production мок отключён всегда — иначе сайт может не открываться в браузере.
#VITE_DISABLE_TELEGRAM_MOCK=true
# Публичный URL сайта для «Ссылка для записи» (если не задан — в prod используется https://slotty.of.by)
#VITE_PUBLIC_APP_URL=https://slotty.of.by
# Имя бота без @ — для ссылки «Запись» в кабинете мастера (https://t.me/BOT?start=master_…)
#VITE_TELEGRAM_BOT_USERNAME=your_bot_username
# Короткое имя Mini App в BotFather (опционально) — прямое открытие приложения: https://t.me/BOT/shortname
#VITE_TELEGRAM_WEBAPP_SHORT_NAME=
# Google OAuth Web client id (Console → Credentials → OAuth 2.0 Client IDs)
#VITE_GOOGLE_CLIENT_ID=
# Sentry (optional)
#VITE_SENTRY_DSN=
#VITE_SENTRY_ENVIRONMENT=staging

# --- SEO / sitemap (runtime на slotty-web, не только build) ---
# URL API без /api — для прокси /sitemap-masters.xml на фронте (обычно = VITE_API_URL)
#SITEMAP_API_BASE=https://slotty-api-production.up.railway.app
# Пропустить post-build prerender: SKIP_PRERENDER=1

# --- Analytics (optional; без ID провайдеры не загружаются) ---
#VITE_YANDEX_METRIKA_ID=
#VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
#VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

# --- E2E SEO smoke (optional) ---
#E2E_BASE_URL=http://localhost:5173
#E2E_PUBLISHED_MASTER_ID=uuid-of-published-master
# Ручная оплата Pro по банковским реквизитам (backend env)
#MANUAL_PAYMENT_RECIPIENT_FULL_NAME=Титовец Данила Игоревич
#MANUAL_PAYMENT_BANK_NAME=ОАО «АСБ Беларусбанк»
#MANUAL_PAYMENT_IBAN=BY…
#MANUAL_PAYMENT_BIC=AKBBBY2X
#MANUAL_PAYMENT_CURRENCY=BYN
#MANUAL_PAYMENT_PRO_AMOUNT=30
#MANUAL_PAYMENT_FEE_COVERED_BY=slotty
# Поиск адреса — через backend /api/geo (Nominatim).
# VITE_MAP_PROVIDER=osm|yandex|none  (по умолчанию osm)
# Опционально Яндекс JS API (не обязателен):
#VITE_YANDEX_MAPS_API_KEY=
#VITE_MAP_PROVIDER=osm
