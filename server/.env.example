PORT=4000
DATABASE_URL=
JWT_SECRET=
TELEGRAM_BOT_TOKEN=
CLIENT_URL=http://localhost:5173
WEB_APP_URL=

# Вебхук для /start и /help: полный URL бэкенда + секрет (оба задайте вместе; после деплоя снова `npm run telegram:setup`).
# TELEGRAM_WEBHOOK_URL=https://YOUR_API_HOST/api/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=

# Загрузка аватаров (Supabase Storage; bucket по умолчанию — profile)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PROFILE_BUCKET=profile

# В production: разрешить PATCH /api/masters/me/subscription/mock (true). В development mock включён без флага.
# ALLOW_SUBSCRIPTION_MOCK=true
