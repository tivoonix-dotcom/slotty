# Скопируйте: cp server/.env.example server/.env  (Windows: copy server\.env.example server\.env)
PORT=4000
# За reverse proxy (Railway / Nginx): 1 = один hop. В dev не задавайте (false).
# TRUST_PROXY=1
# Cloudflare перед приложением: TRUST_PROXY=2 и/или TRUST_CLOUDFLARE_HEADERS=true (иначе CF-Connecting-IP игнорируется).
# TRUST_PROXY=2
# TRUST_CLOUDFLARE_HEADERS=true
DATABASE_URL=
JWT_SECRET=
TELEGRAM_BOT_TOKEN=
# Chat ID админа для уведомлений о заявках на смену категории (опционально)
# TELEGRAM_ADMIN_CHAT_ID=
# Имя бота без @ (опционально; иначе фронт получит его через GET /api/public/config → getMe)
# TELEGRAM_BOT_USERNAME=
# Google Sign-In (тот же Client ID, что VITE_GOOGLE_CLIENT_ID на фронте)
# GOOGLE_CLIENT_ID=
# Client secret того же OAuth Web client — для входа/привязки из Telegram (redirect flow)
# GOOGLE_CLIENT_SECRET=
# Полный redirect URI (если PUBLIC_API_URL не задан): https://YOUR_API_HOST/api/auth/google/oauth/callback
# GOOGLE_OAUTH_REDIRECT_URI=
# CORS: также разрешены https://slotty.of.by, www.slotty.of.by, slotty-production.up.railway.app
CLIENT_URL=http://localhost:5173
# HTTPS URL фронта / Mini App (обязательно со схемой https:// на проде)
# WEB_APP_URL=https://slotty.of.by

# /start и /help: вебхук на бэкенд (обязательно на проде). При старте сервер сам вызовет setWebhook.
# Вариант 1 — полный URL:
# TELEGRAM_WEBHOOK_URL=https://YOUR_API_HOST/api/telegram/webhook
# Вариант 2 — только хост API (допишется /api/telegram/webhook); на Railway часто хватает RAILWAY_PUBLIC_DOMAIN:
# PUBLIC_API_URL=https://YOUR_API_HOST
# TELEGRAM_WEBHOOK_SECRET=случайная_строка
# Локально без HTTPS: TELEGRAM_USE_POLLING=true (long polling, вебхук не нужен)

# Загрузка аватаров (Supabase Storage; bucket по умолчанию — profile)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PROFILE_BUCKET=profile

# В production: разрешить PATCH /api/masters/me/subscription/mock (true). В development mock включён без флага.
# ALLOW_SUBSCRIPTION_MOCK=true

# Напоминания о записи в Telegram + in-app (за ~24ч и ~1ч). Интервал проверки — мс, по умолчанию 300000 (5 мин).
# APPOINTMENT_REMINDERS_ENABLED=true
# APPOINTMENT_REMINDERS_INTERVAL_MS=300000

# Resend (письма: подтверждение email, сброс пароля). Без ключа в dev ссылки логируются в консоль сервера.
# RESEND_API_KEY=re_...
# RESEND_FROM=SLOTTY <noreply@yourdomain.com>

# Sentry (optional — без DSN только warning в логах)
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=staging

# Google link handoff: memory (single API instance) | redis (production multi-instance)
# GOOGLE_LINK_HANDOFF_STORE=memory
# REDIS_URL=redis://...
# API_REPLICA_COUNT=1
